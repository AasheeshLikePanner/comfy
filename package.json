{
  "name": "cleo",
  "version": "1.0.0",
  "description": "Local PostgreSQL visualizer - explore your database schema with a cute cat",
  "type": "module",
  "bin": {
    "cleo": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun --watch run src/cli.ts",
    "dev:client": "cd client && npm run dev",
    "dev:all": "bun run dev:client & bun run dev",
    "build": "bun build src/cli.ts --outdir dist --target bun",
    "build:esbuild": "node scripts/build.js",
    "build:client": "cd client && npm run build",
    "build:all": "npm run build:client && npm run build:esbuild",
    "prepublishOnly": "npm run build:all",
    "start": "node dist/cli.js",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "hono": "^4.0.0",
    "open": "^11.0.0",
    "pg": "^8.11.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/pg": "^8.10.9",
    "bun-types": "^1.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "postgresql",
    "database",
    "visualizer",
    "postgres",
    "cli",
    "tool"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/cleo"
  },
  "files": [
    "dist",
    "client/dist"
  ]
}